<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cv_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/cv_primary"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Top Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Avatar + Name -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/bg_avatar">

                        <TextView
                            android:id="@+id/tvUserInitial"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:fontFamily="@font/inter"
                            android:text="@string/user_avatar_letter"
                            android:textColor="#FFFFFF"
                            android:textFontWeight="500"
                            android:textSize="14sp" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter"
                            android:text="@string/welcome"
                            android:textColor="#99FFFFFF"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvUserName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter"
                            android:text="@string/user"
                            android:textColor="#FFFFFF"
                            android:textFontWeight="500"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Icons -->
                <ImageView
                    android:id="@+id/ivSearch"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_icon_btn"
                    android:padding="8dp"
                    android:src="@drawable/ic_search" />

                <FrameLayout
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:background="@drawable/bg_icon_btn">

                    <ImageView
                        android:id="@+id/btnNotification"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="8dp"
                        android:src="@drawable/ic_notifications" />

                    <TextView
                        android:id="@+id/tvNotificationBadge"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="-2dp"
                        android:layout_marginEnd="-2dp"
                        android:gravity="center"
                        android:background="@drawable/bg_notification_badge"
                        android:text="0"
                        android:textColor="@android:color/white"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:visibility="gone"/>

                </FrameLayout>

            </LinearLayout>

            <!-- Storage Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_storage_card"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:fontFamily="@font/inter"
                    android:text="@string/space_use"
                    android:textColor="#99FFFFFF"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tvStorageInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter"
                    android:text="@string/average_maga"
                    android:textColor="#FFFFFF"
                    android:textFontWeight="500"
                    android:textSize="14sp" />

                <ProgressBar
                    android:id="@+id/storageProgress"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="5dp"
                    android:layout_marginTop="10dp"
                    android:max="100"
                    android:progress="45"
                    android:progressBackgroundTint="#33FFFFFF"
                    android:progressTint="#FFFFFF" />

            </LinearLayout>

        </LinearLayout>

        <!-- Body -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Quick Actions -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/inter"
                android:letterSpacing="0.08"
                android:text="@string/procdure"
                android:textColor="@color/cv_text_hint"
                android:textSize="11sp" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:columnCount="2"
                android:rowCount="2">

                <LinearLayout
                    android:id="@+id/cardUpload"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_quick_action"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        app:tint="@color/cv_accent"
                        android:src="@drawable/ic_upload" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/inter"
                        android:text="@string/upload_file"
                        android:textColor="@color/cv_text_muted"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardNewFolder"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_quick_action"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        app:tint="@color/cv_accent"
                        android:src="@drawable/ic_folder_add" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/inter"
                        android:text="@string/new_file"
                        android:textColor="@color/cv_text_muted"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardShare"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_quick_action"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        app:tint="@color/cv_accent"
                        android:src="@drawable/ic_share" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/inter"
                        android:text="@string/share"
                        android:textColor="@color/cv_text_muted"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardFavorites"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_quick_action"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        app:tint="@color/cv_accent"
                        android:src="@drawable/ic_star" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/inter"
                        android:text="@string/favorite"
                        android:textColor="@color/cv_text_muted"
                        android:textSize="11sp" />
                </LinearLayout>

            </GridLayout>

            <!-- Recent Files -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/inter"
                android:letterSpacing="0.08"
                android:text="@string/end_file"
                android:textColor="@color/cv_text_hint"
                android:textSize="11sp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRecentFiles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

            <TextView
                android:id="@+id/tvEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:text="@string/no_files_uploaded_yet"
                android:textColor="@color/cv_text_secondary"
                android:textSize="16sp"
                android:visibility="gone"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>