<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.CloudVault"
        parent="Theme.MaterialComponents.DayNight.NoActionBar">

        <item name="colorPrimary">@color/cv_primary</item>
        <item name="colorPrimaryVariant">@color/cv_secondary</item>
        <item name="colorOnPrimary">@android:color/white</item>

        <item name="colorControlActivated">@color/cv_accent</item>
        <item name="colorControlNormal">@color/cv_border</item>
        <item name="colorControlHighlight">@color/cv_surface</item>
        <item name="android:colorBackground">@color/black</item>

        <item name="android:fontFamily">@font/inter</item>
        <item name="fontFamily">@font/inter</item>

    </style>
    <style name="CloudVault.PopupMenu" parent="Widget.MaterialComponents.PopupMenu">

        <item name="android:popupBackground">@drawable/bg_dot</item>

        <item name="android:textColor">@android:color/white</item>

    </style>

    <style name="Theme.CloudVault"
        parent="Base.Theme.CloudVault" />

    <style name="Theme.CloudVault.Splash"
        parent="Theme.SplashScreen">

        <item name="windowSplashScreenBackground">@color/cv_danger</item>
        <item name="postSplashScreenTheme">@style/Theme.CloudVault</item>
        <item name="android:windowFullscreen">true</item>

    </style>

    <style name="CloudVault.TextInputLayout"
        parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <item name="boxBackgroundColor">@color/cv_surface</item>
        <item name="boxStrokeColor">@color/cv_border</item>
        <item name="boxStrokeWidth">1dp</item>

        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>

        <item name="hintTextColor">@color/cv_text_hint</item>
        <item name="android:textColorHint">@color/cv_text_hint</item>

    </style>

    <style name="CloudVault.OutlinedButton"
        parent="Widget.MaterialComponents.Button.OutlinedButton">

        <item name="strokeColor">@color/cv_border</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/cv_text_muted</item>

    </style>

</resources>