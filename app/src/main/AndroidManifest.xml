<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:label="@string/app_name"
        android:allowBackup="true"
        android:usesCleartextTraffic="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CloudVault">
        <activity
            android:name="com.abdallahshabat.cloudvault.ui.auth.RegisterActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name="com.abdallahshabat.cloudvault.ui.auth.LoginActivity"
            android:exported="false" />
        <activity
            android:name="com.abdallahshabat.cloudvault.ui.splash.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.CloudVault">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name="com.abdallahshabat.cloudvault.ui.home.MainActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".ui.about.AboutActivity"
            android:exported="false" />
        <activity
            android:name=".ui.help.HelpActivity"
            android:exported="false" />
        <activity
            android:name=".ui.privacy.PrivacyActivity"
            android:exported="false" />

    </application>

</manifest>